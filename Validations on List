    {
        [Test]
        public void Test_FinalList_UniqueValues()
        {
            // Get the list from the Program class
            List<Student> actualList = Program.FinalList();
            // Logic: A list has unique values if its count equals the count of its distinct elements
            int uniqueCount = actualList.Select(s => s.Id).Distinct().Count();
            int totalCount = actualList.Count;
            // Assert whether the actual unique count is equal to the expected total count
            Assert.AreEqual(totalCount, uniqueCount);
        }
        [Test]
